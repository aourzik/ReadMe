# Copier ce fichier en .env et remplir les valeurs

# ── Base de données ───────────────────────────────────────────────────────────
# Local :
DATABASE_URL="postgresql://postgres:readme_dev_password@localhost:5432/readme_db"
# Railway fournit automatiquement cette variable (DATABASE_URL) — ne pas la redéfinir

# ── Auth ──────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
JWT_SECRET="CHANGE_MOI_MIN_32_CHARS_EN_PRODUCTION"

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Liste des origines autorisées, séparées par des virgules
# En production : ajouter le domaine de ta landing page
CORS_ORIGINS="http://localhost:8080,http://localhost:3001,https://ton-domaine.com"
